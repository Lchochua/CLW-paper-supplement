Cell["Global Free Trade (zero tariffs)", "Subsubsection",
 CellChangeTimes->{{3.8848366924325438`*^9, 3.8848366969443483`*^9}, {
  3.982120276587391*^9, 
  3.9821202836767445`*^9}},ExpressionUUID->"0ff7d0a7-78fd-486d-933b-\
2dc3962fa75e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["W", "aGFT"], "=", 
   RowBox[{
    RowBox[{
     FractionBox["1", "9"], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "5"}], " ", 
        SubsuperscriptBox["e", "a", "2"]}], "+", 
       SubsuperscriptBox["e", "b", "2"], "+", 
       RowBox[{"2", " ", 
        SubscriptBox["e", "a"], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"9", " ", "\[Alpha]"}], "-", 
          SubscriptBox["e", "b"], "-", 
          SubscriptBox["e", "c"]}], ")"}]}], "+", 
       RowBox[{
        SubscriptBox["e", "b"], " ", 
        SubscriptBox["e", "c"]}], "+", 
       SubsuperscriptBox["e", "c", "2"]}], ")"}]}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SubscriptBox["e", "a"], "->", "1"}], ",", 
      RowBox[{
       SubscriptBox["e", "b"], "->", "1"}], ",", 
      RowBox[{
       SubscriptBox["e", "c"], "->", "1"}]}], "}"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.884836706771353*^9, 3.884836727022285*^9}, 
